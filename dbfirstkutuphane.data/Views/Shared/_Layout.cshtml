@{
    var rol = Context.Session.GetString("Rol");
    var kullanici = Context.Session.GetString("KullaniciAdi");
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Orca Kütüphanesi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="ocean-bg">
        <div class="ocean-deco ocean-whale-1"></div>
        <div class="ocean-deco ocean-whale-2"></div>
        <div class="ocean-deco ocean-whale-3"></div>
        <div class="ocean-deco ocean-shark-1"></div>
        <div class="ocean-deco ocean-shark-2"></div>
        <div class="ocean-deco ocean-shark-3"></div>
        <div class="ocean-deco ocean-orca-1"></div>
        <div class="ocean-deco ocean-orca-2"></div>
        <div class="ocean-deco ocean-orca-3"></div>
    </div>
    <div class="page-content">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-navy-gold border-bottom box-shadow mb-0">
            <div class="container px-4 px-lg-5">
                <a class="navbar-brand fw-bold" href="/Home/Index">🐋 Orca Kütüphanesi</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">Ana Sayfa</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Kitap/Index">Kitaplar</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Odunc/Index">Ödünç İşlemleri</a></li>
                        @if (rol == "Admin")
                        {
                            <li class="nav-item"><a class="nav-link" href="/Uye/Index">Üyeler</a></li>
                        }
                        <li class="nav-item">
                            <span class="nav-link text-warning">@kullanici (@rol)</span>
                        </li>
                        <li class="nav-item"><a class="nav-link" href="/Giris/Logout">Çıkış</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @RenderSection("Hero", required: false)
    <div class="container px-4 px-lg-5 my-4 flex-grow-1">
        <main role="main" class="pb-3">@RenderBody()</main>
    </div>
    <footer class="footer-navy py-3 mt-auto">
        <div class="container text-center">&copy; 2026 - Orca Kütüphanesi</div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    </div>
</body>
</html>