@model dbfirstkutuphane.Models.Kitaplar
@{
    ViewData["Title"] = "Kitap Sil";
}
<h2 class="page-title">Kitap Sil</h2>
<h4>Bu kitabı silmek istediğinize emin misiniz?</h4>
<dl class="row">
    <dt class="col-sm-2">Ad</dt>
    <dd class="col-sm-10">@Model.Ad</dd>
    <dt class="col-sm-2">Yazar</dt>
    <dd class="col-sm-10">@Model.Yazar</dd>
    <dt class="col-sm-2">ISBN</dt>
    <dd class="col-sm-10">@Model.ISBN</dd>
    <dt class="col-sm-2">Stok</dt>
    <dd class="col-sm-10">@Model.Stok</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="KitapId" />
    <button type="submit" class="btn btn-danger">Sil</button>
    <a href="/Kitap/Index" class="btn btn-secondary">Geri</a>
</form>